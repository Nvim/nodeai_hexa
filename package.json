{
  "name": "nodeai2",
  "version": "1.0.0",
  "description": "Formation Node.js + LLM local avec Ollama et Fastify",
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx --watch src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "@fastify/type-provider-typebox": "^5.0.0",
    "@sinclair/typebox": "^0.34.0",
    "better-sqlite3": "^12.10.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "gray-matter": "^4.0.3",
    "pino-pretty": "^13.1.3",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}